{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    {
      "src": "/CSS/(.*)",
      "dest": "/api/CSS/$1"
    },
    {
      "src": "/imagenes/(.*)",
      "dest": "/api/imagenes/$1"
    },
    {
      "src": "/PHP/(.*)",
      "dest": "/api/PHP/$1"
    },
    {
      "src": "/(.*).php",
      "dest": "/api/$1.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}